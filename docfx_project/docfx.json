{
	"metadata": [
		{
			"src": [
				{
					"files": [ "SistemaInventario.Api.csproj" ],
					"src": "../SistemaInventario.Api"
				}
			],
			"dest": "api"
		}
	],
	"build": {
		"content": [
			{
				"files": [ "api/*.yml", "api/SistemaInventario.Api/**.yml" ],
				"src": "."
			},
			{
				"files": [ "articles/**/*.md", "index.md" ],
				"src": "."
			}
		],
		"dest": "_site",
		"template": [ "default", "modern" ]
	}
}