{
	"metadata": [
		{
			"src": [
				{
					"files": [ "../SistemaInventario.Api/*.csproj" ],
					"src": ".."
				}
			],
			"dest": "api",
			"disableDefaultFilter": false
		}
	],
	"build": {
		"content": [
			{
				"files": [ "api/**/*.yml", "api/*.yml" ]
			},
			{
				"files": [ "articles/**/*.md", "index.md" ]
			}
		],
		"resource": [
			{
				"files": [ "images/**" ]
			}
		],
		"output": "_site",
		"template": [ "default", "modern" ]
	}
}